{
  "version": "2.0.0",
  "fecha_actualizacion": "2026-04-26",
  "norma": "RD 073-2010-VIVIENDA / E.060",
  "especialidad": "Estructuras (OE.2)",
  "metodos_calculo": {
    "und_cant": {
      "nombre": "Unidad — Cantidad simple",
      "campos": [
        "cantidad",
        "veces"
      ],
      "formula": "=F{r}*J{r}"
    },
    "m_largo": {
      "nombre": "Longitud — Largo directo",
      "campos": [
        "cantidad",
        "largo",
        "veces"
      ],
      "formula": "=F{r}*G{r}*J{r}"
    },
    "m2_largo_ancho": {
      "nombre": "Área — Largo × Ancho",
      "campos": [
        "cantidad",
        "largo",
        "ancho",
        "veces"
      ],
      "formula": "=F{r}*G{r}*H{r}*J{r}"
    },
    "m2_perimetro_alt": {
      "nombre": "Área — Perímetro × Altura",
      "campos": [
        "cantidad",
        "largo",
        "ancho",
        "alto",
        "veces"
      ],
      "formula": "=F{r}*2*(G{r}+H{r})*I{r}*J{r}"
    },
    "m2_lateral": {
      "nombre": "Área — Encofrado lateral",
      "campos": [
        "cantidad",
        "largo",
        "ancho",
        "alto",
        "veces"
      ],
      "formula": "=F{r}*(2*G{r}+2*H{r})*I{r}*J{r}"
    },
    "m3_l_a_h": {
      "nombre": "Volumen — Largo × Ancho × Alto",
      "campos": [
        "cantidad",
        "largo",
        "ancho",
        "alto",
        "veces"
      ],
      "formula": "=F{r}*G{r}*H{r}*I{r}*J{r}"
    },
    "m3_area_esp": {
      "nombre": "Volumen — Área × Espesor",
      "campos": [
        "cantidad",
        "largo",
        "ancho",
        "alto",
        "veces"
      ],
      "formula": "=F{r}*G{r}*H{r}*I{r}*J{r}"
    },
    "kg_acero": {
      "nombre": "Acero — Cantidad × Largo × peso/m",
      "campos": [
        "cantidad",
        "largo",
        "veces",
        "diametro"
      ],
      "formula": "=F{r}*G{r}*0.560*J{r}"
    }
  },
