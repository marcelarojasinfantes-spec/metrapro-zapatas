  "especialidad": "Estructuras (OE.2)",
  "metodos_calculo": {
    "und_cant": {
      "nombre": "Unidad — Cantidad simple",
      "campos": ["cantidad", "veces"],
      "formula": "=F{r}*J{r}",
      "memoria": "{cantidad} × {veces} = {total} {unidad}"
    },
    "m_largo": {
      "nombre": "Longitud — Largo directo",
      "campos": ["cantidad", "largo", "veces"],
      "formula": "=F{r}*G{r}*J{r}",
      "memoria": "{cantidad} × {largo} m × {veces} = {total} m"
    },
    "m2_largo_ancho": {
      "nombre": "Área — Largo × Ancho",
      "campos": ["cantidad", "largo", "ancho", "veces"],
      "formula": "=F{r}*G{r}*H{r}*J{r}",
      "memoria": "{cantidad} × {largo} × {ancho} × {veces} = {total} m²"
    },
    "m2_perimetro_alt": {
      "nombre": "Área — Perímetro × Altura: 2(L+A)×H",
      "campos": ["cantidad", "largo", "ancho", "alto", "veces"],
      "formula": "=F{r}*2*(G{r}+H{r})*I{r}*J{r}",
      "memoria": "{cantidad} × 2({largo}+{ancho}) × {alto} × {veces} = {total} m²"
    },
    "m2_lateral": {
      "nombre": "Área — Encofrado lateral solo (perímetro × altura sin tapas)",
      "campos": ["cantidad", "largo", "ancho", "alto", "veces"],
      "formula": "=F{r}*(2*G{r}+2*H{r})*I{r}*J{r}",
      "memoria": "{cantidad} × (2×{largo}+2×{ancho}) × {alto} × {veces} = {total} m²"
    },
    "m3_l_a_h": {
      "nombre": "Volumen — Largo × Ancho × Alto",
      "campos": ["cantidad", "largo", "ancho", "alto", "veces"],
      "formula": "=F{r}*G{r}*H{r}*I{r}*J{r}",
      "memoria": "{cantidad} × {largo} × {ancho} × {alto} × {veces} = {total} m³"
    },
    "m3_area_esp": {
      "nombre": "Volumen — Área × Espesor (losas, pavimentos)",
      "campos": ["cantidad", "largo", "ancho", "alto", "veces"],
      "formula": "=F{r}*G{r}*H{r}*I{r}*J{r}",
      "memoria": "{cantidad} × {largo}×{ancho} × {alto} × {veces} = {total} m³"
    },
    "kg_acero": {
      "nombre": "Acero — Cantidad × Largo × peso/m",
      "campos": ["cantidad", "largo", "veces", "diametro"],
      "formula": "=F{r}*G{r}*{peso}*J{r}",
      "memoria": "{cantidad} × {largo} m × {peso} kg/m × {veces} = {total} kg"
    },
    "glb": {
      "nombre": "Global — Solo cantidad",
      "campos": ["cantidad"],
      "formula": "=F{r}",
      "memoria": "{cantidad} glb"
    }
  },
